# Environment for the Vercel relay. Copy to .env for local dev,
# set the same values in Vercel project settings for production.

NODE_ENV=development
PORT=3000

# Shared secret the iOS app sends in X-Voxelio-Key on every request.
IOS_SHARED_SECRET=changeme

# SpaceComputer Orbitport (cosmic randomness)
# Get keys from https://spacecomputer.deform.cc/ctrngearlyaccess
ORBITPORT_CLIENT_ID=
ORBITPORT_CLIENT_SECRET=
ORBITPORT_AUDIENCE=https://op.spacecomputer.io/api
ORBITPORT_TOKEN_URL=https://auth.spacecomputer.io/oauth/token
ORBITPORT_TRNG_URL=https://op.spacecomputer.io/api/v1/services/trng

# Swarm bee gateway used to pin captured scenes.
SWARM_BEE_URL=https://api.gateway.ethswarm.org
SWARM_POSTAGE_BATCH_ID=

# Base Sepolia minter wallet + RealityProof contract.
BASE_SEPOLIA_RPC=https://sepolia.base.org
MINTER_PRIVATE_KEY=
REALITY_PROOF_ADDRESS=

# Optional: ENS subdomain owner for "<token>.realityproof.eth"
ENS_PARENT_DOMAIN=realityproof.eth
ENS_RESOLVER_PRIVATE_KEY=
